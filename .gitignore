```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map

# Environment variables
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Distribution / packaging
.Python
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Testing
.pytest_cache/
.mypy_cache/
.tox/
.nox/

# OS generated files
.DS_Store
Thumbs.db

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```