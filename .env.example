# Variables de entorno para Firebase
# Copia este archivo a .env y reemplaza los valores con tu configuración de Firebase

VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto_id
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_messaging_sender_id
VITE_FIREBASE_APP_ID=tu_app_id

# Instrucciones:
# 1. Ve a https://console.firebase.google.com/
# 2. Crea un nuevo proyecto o selecciona uno existente
# 3. Ve a Configuración del proyecto > General
# 4. Baja hasta "Tus apps" y crea una app web (</>)
# 5. Copia las credenciales de firebaseConfig y reemplaza los valores arriba
